@model IEnumerable<GameStoreMVC.Models.Game>

@{
    ViewData["Title"] = "Home";
    var destaque = Model.FirstOrDefault(g => g.EmDestaque);
    var categorias = new[] { "RPG", "Ação", "Corrida", "Aventura" };
}


<section class="gs-hero d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4 fw-bold text-white">Domine o Jogo</h1>
                <p class="text-light fs-5">Os lançamentos mais esperados e as melhores ofertas em um só lugar.<br />Upgrade no seu setup começa aqui.</p>
                <a href="#destaques" class="btn btn-success btn-lg mt-2 px-4">Ver Ofertas</a>
            </div>
            <div class="col-md-6 d-none d-md-block text-center">
                <img src="https://via.placeholder.com/500x300/0d0d1a/00ff88?text=GAMING+ZONE" class="img-fluid rounded" alt="Gaming" />
            </div>
        </div>
    </div>
</section>


<section class="py-3 gs-category-bar">
    <div class="container text-center">
        @foreach (var cat in categorias)
        {
            <a asp-controller="Game" asp-action="Index" class="btn btn-outline-secondary btn-sm me-2 mb-2">@cat</a>
        }
    </div>
</section>


<section id="destaques" class="py-5">
    <div class="container">
        <h2 class="text-white fw-bold mb-4">Em Destaque</h2>
        <div class="row">
            @foreach (var game in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                    <div class="card gs-card h-100">
                        <img src="@(game.ImagemUrl ?? "https://via.placeholder.com/300x200/1a1a2e/00ff88?text=GAME")"
                             class="card-img-top" alt="@game.Nome" style="height:180px;object-fit:cover;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-white fw-bold">@game.Nome</h5>
                            <p class="text-muted small">@game.Descricao</p>
                            <p class="text-success fw-bold fs-5 mt-auto">R$ @game.Preco.ToString("N2")</p>
                            <a href="#" class="btn btn-success btn-sm mt-1">Comprar</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2 mt-2">
                                    <a asp-controller="Game" asp-action="Editar" asp-route-id="@game.Id"
                                       class="btn btn-warning btn-sm flex-fill">Editar</a>
                                    <form asp-controller="Game" asp-action="Excluir" method="post" class="flex-fill"
                                          onsubmit="return confirm('Excluir este jogo?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@game.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm w-100">Excluir</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="text-center mt-3">
                <a asp-controller="Game" asp-action="Criar" class="btn btn-success px-4">
                    <i class="fas fa-plus me-2"></i>Cadastrar Novo Jogo
                </a>
            </div>
        }
    </div>
</section>
