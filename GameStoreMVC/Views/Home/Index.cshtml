@{
    ViewData["Title"] = " Games | Home";
}

<div class="p-5 mb-5 rounded-3 jumbotron-hero shadow-sm"
     style="background: linear-gradient(rgba(0, 35, 102, 0.7), rgba(106, 90, 205, 0.5)),
            url('/img/fundo.jpg') no-repeat center/cover; border-bottom: 4px solid var(--accent-purple);">

    <div class="container-fluid py-5 text-white">
        <h1 class="display-5 fw-bold">Domine o Jogo</h1>
        <p class="col-md-8 fs-4 opacity-90">Os lançamentos mais esperados e as melhores ofertas em um só lugar. Upgrade no seu setup começa aqui.</p>
        <button class="btn btn-success btn-lg px-5 shadow" type="button">Ver Ofertas</button>
    </div>
</div>

<div class="container mb-5">
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <span class="badge rounded-pill p-2 px-3 shadow-sm" style="background-color: var(--light-blue-bg); color: var(--primary-navy); border: 1px solid rgba(0,35,102,0.1);">RPG</span>
        <span class="badge rounded-pill p-2 px-3 shadow-sm" style="background-color: var(--light-blue-bg); color: var(--primary-navy); border: 1px solid rgba(0,35,102,0.1);">Ação</span>
        <span class="badge rounded-pill p-2 px-3 shadow-sm" style="background-color: var(--light-blue-bg); color: var(--primary-navy); border: 1px solid rgba(0,35,102,0.1);">Corrida</span>
        <span class="badge rounded-pill p-2 px-3 shadow-sm" style="background-color: var(--light-blue-bg); color: var(--primary-navy); border: 1px solid rgba(0,35,102,0.1);">Aventura</span>
    </div>
</div>

<div class="container">
    <h2 class="mb-4 fw-bold" style="color: var(--primary-navy);">
        <i class="bi bi-star-fill me-2" style="color: var(--accent-purple);"></i>Em Destaque
    </h2>

    <div class="row">
    </div>
</div>