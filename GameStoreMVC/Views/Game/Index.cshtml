@model IEnumerable<GameStoreMVC.Models.Game>

@{
    ViewData["Title"] = "Gerenciar Games";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white fw-bold"><i class="fas fa-gamepad me-2 text-success"></i>Gerenciar Games</h2>
        <a asp-action="Criar" class="btn btn-success">
            <i class="fas fa-plus me-2"></i>Novo Game
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Imagem</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Preço</th>
                    <th>Destaque</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td>
                            <img src="@(game.ImagemUrl ?? "https://via.placeholder.com/60x40/1a1a2e/00ff88?text=G")"
                                 width="60" height="40" style="object-fit:cover;border-radius:4px;" />
                        </td>
                        <td class="text-white fw-bold">@game.Nome</td>
                        <td><span class="badge bg-secondary">@game.Categoria</span></td>
                        <td class="text-success fw-bold">R$ @game.Preco.ToString("N2")</td>
                        <td>
                            @if (game.EmDestaque)
                            {
                                <span class="badge bg-success"><i class="fas fa-star me-1"></i>Sim</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Não</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@game.Id" class="btn btn-warning btn-sm me-1">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <form asp-action="Excluir" method="post" class="d-inline"
                                  onsubmit="return confirm('Confirma a exclusão de @game.Nome?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@game.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i> Excluir
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
