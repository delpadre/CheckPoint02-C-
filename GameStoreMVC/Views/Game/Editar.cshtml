@model GameStoreMVC.Models.Game

@{
    ViewData["Title"] = "Editar Game";
    var categorias = new[] { "RPG", "Ação", "Corrida", "Aventura", "Esporte", "Estratégia" };
}

<section class="gs-auth-section d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="gs-card p-4 rounded-3">
                    <div class="text-center mb-4">
                        <h3 class="text-white fw-bold">Editar Game</h3>
                        <p class="text-muted small">Atualize as informações do título</p>
                    </div>

                    <form asp-action="Editar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CriadoEm" />

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label text-light small">Nome do Jogo</label>
                            <input asp-for="Nome" class="form-control gs-input" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Descricao" class="form-label text-light small">Descrição Curta</label>
                            <textarea asp-for="Descricao" class="form-control gs-input" rows="3"></textarea>
                            <span asp-validation-for="Descricao" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Preco" class="form-label text-light small">Preço (R$)</label>
                                <input asp-for="Preco" class="form-control gs-input" />
                                <span asp-validation-for="Preco" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Categoria" class="form-label text-light small">Categoria</label>
                                <select asp-for="Categoria" class="form-select gs-input">
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ImagemUrl" class="form-label text-light small">URL da Capa</label>
                            <input asp-for="ImagemUrl" class="form-control gs-input" />
                        </div>
                        <div class="mb-4 form-check">
                            <input asp-for="EmDestaque" class="form-check-input" type="checkbox" />
                            <label asp-for="EmDestaque" class="form-check-label text-light small">Exibir em Destaque</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning flex-fill fw-bold">Atualizar Game</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
