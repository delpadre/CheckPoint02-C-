@model GameStoreMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Entrar na Arena";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-4 shadow-lg p-4 rounded-4" style="background-color: #ffffff; border: 1px solid var(--light-blue-bg);">

        <div class="text-center mb-4">
            <h3 class="fw-bold" style="color: var(--primary-navy);">Login</h3>
            <p class="text-muted small">Entre para gerenciar seus games</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label small fw-semibold" style="color: var(--primary-navy);">E-mail</label>
                <input asp-for="Email" class="form-control form-control-sm border-secondary-subtle"
                       type="email" placeholder="nome@exemplo.com" required
                       style="background-color: #f8f9fa;" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold" style="color: var(--primary-navy);">Senha</label>
                <input asp-for="Senha" class="form-control form-control-sm border-secondary-subtle"
                       type="password" placeholder="••••••••" required
                       style="background-color: #f8f9fa;" />
            </div>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger py-2 px-3 small border-0 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Erro
                </div>
            }

            <div class="d-grid gap-2">
                <button type="submit" class="btn text-white btn-sm fw-bold shadow-sm"
                        style="background-color: var(--accent-purple); border: none; padding: 10px;">
                    Acessar Arena
                </button>
            </div>

            <hr class="opacity-25 mt-4" style="color: var(--primary-navy);">

            <div class="text-center mt-3">
                <p class="text-muted small mb-1">Ainda não tem uma conta?</p>
                <a asp-action="CriarConta" asp-controller="Login" class="text-decoration-none small fw-bold"
                   style="color: var(--accent-purple);">
                    Criar nova conta
                </a>
            </div>
        </form>
    </div>
</div>