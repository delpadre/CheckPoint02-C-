@model GameStoreMVC.Models.RegisterViewModel

@{
    ViewData["Title"] = "Nova Conta";
    Layout = "_Layout";
}

<section class="gs-auth-section d-flex align-items-center justify-content-center py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="gs-card p-4 rounded-3">
                    <div class="text-center mb-4">
                        <h3 class="text-white fw-bold">Criar Conta</h3>
                        <p class="text-muted small">Junte-se à nossa comunidade gamer</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger small py-2">
                            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                        </div>
                    }

                    <form asp-action="CriarConta" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label text-light small">Nome</label>
                            <input asp-for="Nome" class="form-control gs-input" placeholder="Seu nome" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label text-light small">E-mail</label>
                            <input asp-for="Email" class="form-control gs-input" placeholder="user@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Senha" class="form-label text-light small">Senha</label>
                            <input asp-for="Senha" class="form-control gs-input" placeholder="Crie uma senha forte" />
                            <span asp-validation-for="Senha" class="text-danger small"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmacaoSenha" class="form-label text-light small">Confirmar Senha</label>
                            <input asp-for="ConfirmacaoSenha" class="form-control gs-input" placeholder="Repita sua senha" />
                            <span asp-validation-for="ConfirmacaoSenha" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-success w-100 fw-bold">Finalizar Cadastro</button>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted small">Já possui conta?</p>
                        <a asp-action="Login" class="text-success fw-bold text-decoration-none">Fazer Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
