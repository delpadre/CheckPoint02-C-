<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark border-bottom">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    LOJA <span style="color: var(--accent-purple);">GAME</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarMain" aria-controls="navbarMain"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Game" asp-action="Criar">
                                        <i class="bi bi-plus-circle me-1"></i>Novo Jogo
                                    </a>
                                </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                                <li class="nav-item d-flex align-items-center me-3">
                                    <span class="text-light small">
                                        Olá, <strong>@User.Identity.Name</strong>
                                    @if (User.IsInRole("Admin"))
                                    {
                                                <span class="badge ms-1" style="background-color: var(--accent-purple);">Admin</span>
                                    }
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger" asp-controller="Login" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i>Sair
                                    </a>
                                </li>
                        }
                        else
                        {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Login" asp-action="Login">
                                        <i class="bi bi-person me-1"></i>Login
                                    </a>
                                </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @if (TempData["Sucesso"] != null)
        {
                <div class="container mt-3">
                    <div class="alert-success-gs">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Sucesso"]
                    </div>
                </div>
        }
        @RenderBody()
    </main>

    <footer class="pt-5 pb-3 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h4 class="fw-bold mb-3">GAME<span style="color: var(--accent-purple);">STORE</span></h4>
                    <p class="small opacity-75">Sua arena gamer definitiva. Os melhores títulos, as ofertas mais quentes e a maior comunidade de jogadores você encontra aqui.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="fs-5"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="fs-5"><i class="bi bi-discord"></i></a>
                        <a href="#" class="fs-5"><i class="bi bi-twitch"></i></a>
                    </div>
                </div>
                <div class="col-6 col-md-2 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Loja</h6>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index" class="small">Todos os Games</a></li>
                        <li><a href="#" class="small">Lançamentos</a></li>
                        <li><a href="#" class="small">Promoções</a></li>
                    </ul>
                </div>
                <div class="col-6 col-md-2 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Suporte</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="small">Privacidade</a></li>
                        <li><a href="#" class="small">Termos de Uso</a></li>
                        <li><a href="#" class="small">Fale Conosco</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="fw-bold text-uppercase mb-3">Fique por dentro</h6>
                    <div class="input-group input-group-sm mb-3">
                        <input type="email" class="form-control gs-input" placeholder="Seu melhor e-mail">
                        <button class="btn btn-success fw-bold" type="button">OK</button>
                    </div>
                    <p class="opacity-75" style="font-size: 0.75rem;">Receba cupons de desconto exclusivos!</p>
                </div>
            </div>
            <hr class="opacity-25">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mt-3">
                <p class="small mb-0 opacity-75">&copy; 2026 - GameStore. Todos os direitos reservados.</p>
                <div>
                    <i class="bi bi-credit-card-2-back fs-4 ms-2" title="Cartão"></i>
                    <i class="bi bi-qr-code fs-4 ms-2" title="Pix"></i>
                    <i class="bi bi-paypal fs-4 ms-2" title="PayPal"></i>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>