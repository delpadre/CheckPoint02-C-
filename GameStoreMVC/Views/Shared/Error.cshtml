@model GameStoreMVC.Models.ErrorViewModel

@{
    ViewData["Title"] = "Erro";
}

<div class="container py-5 text-center">
    <h1 class="text-danger fw-bold">Ops! Algo deu errado.</h1>
    <p class="text-muted">Ocorreu um erro inesperado. Tente novamente.</p>
    @if (Model.ShowRequestId)
    {
            <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-success mt-3">Voltar para Home</a>
</div>